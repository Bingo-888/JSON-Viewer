{
  "name": "json-viewer",
  "version": "0.1.0",
  "private": true,
  "description": "JSON/JSONC visual editor with tree and code dual-pane",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:server": "npm run dev -w @json-viewer/server",
    "dev:client": "npm run dev -w @json-viewer/client",
    "lint": "eslint \"packages/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
