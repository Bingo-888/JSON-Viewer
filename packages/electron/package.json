{
  "name": "@json-viewer/electron",
  "version": "0.2.0",
  "private": true,
  "description": "JSON Viewer desktop application",
  "author": "JSON Viewer contributors",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && electron .",
    "start": "electron .",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.jsonviewer.app",
    "productName": "JSON Viewer",
    "directories": {
      "output": "../../dist-electron"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../server/dist",
        "to": "server/dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  }
}
